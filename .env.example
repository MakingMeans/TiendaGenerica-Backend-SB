# =============================================================================
# TiendaGenerica Microservices - Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in ALL values.
# DO NOT commit .env to version control.
# Services WILL FAIL if required variables are missing.
# =============================================================================

# =========================
# CRITICAL SECRETS (Required)
# =========================
# These MUST be unique, secure values in production.
# Do NOT use the example values below in production.
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-me-now
GATEWAY_SECRET=your-super-secret-gateway-key-min-32-chars-change-me

# =========================
# DATABASE CONFIGURATION (Required)
# =========================
DB_HOST=mysql
DB_PORT=3306
DB_USER=tienda_user
DB_PASSWORD=tienda_secure_password_change_me

# =========================
# EUREKA SERVICE DISCOVERY (Optional, default: localhost)
# =========================
EUREKA_DEFAULT_ZONE=http://eureka-server-1:8761/eureka/

# =========================
# GATEWAY CONFIGURATION (Optional)
# =========================
GATEWAY_URL=http://localhost:8080
API_GATEWAY_PORT=8080

# =========================
# DATABASE PORT MAPPING (Optional, default: 3306)
# =========================
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root_secure_password_change_me

# =========================
# EUREKA SERVER PORT (Optional, default: 8761)
# =========================
EUREKA_PORT=8761

# =========================
# JAVA OPTIONS (Optional)
# =========================
# Memory settings for JVM. Default: -XX:MaxRAMPercentage=75.0
JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# =========================
# JWT CONFIGURATION (Optional)
# =========================
# JWT expiration in milliseconds (default: 3600000 = 1 hour)
JWT_EXPIRATION=3600000

# =========================
# SPRING BOOT LOGGING (Optional)
# =========================
SPRING_JPA_SHOW_SQL=false

# =========================
# DATABASE INIT (Optional)
# =========================
# DDL strategy: update, validate, create, create-drop (default: update)
SPRING_JPA_HIBERNATE_DDL_AUTO=update
